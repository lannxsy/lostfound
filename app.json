{
  "expo": {
    "name": "todo-list",
    "slug": "todo-list",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "todolist",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.okyzaprabowo.todolist"
    },
    "android": {
      "package": "com.okyzaprabowo.todolist",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "useNextNotificationsApi": true,
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
  "typedRoutes": true,
  "reactCompiler": true,
  "tsconfigPaths": true 

    },
    "notification": {
      "serviceWorkerPath": "/expo-service-worker.js",
      "vapidPublicKey": "BGHNHtDuWDhiDbmFZbtAOCm2d6b4EQMj1CDfP9DELdNHWGBZ0fGifFgdhzWqG7jaDDCpoLsI8cNsYiW2Ch9-5OU"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "2f3da30f-1104-4c09-b16f-f35983962ed9"
      }
    }
  }
}
